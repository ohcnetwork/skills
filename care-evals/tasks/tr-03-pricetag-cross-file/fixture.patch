+// Formats a monetary amount for display. Null/undefined amounts render as an em dash.
+export function formatMoney(
+  amount: number | null | undefined,
+  currency: string,
+): string {
+  if (!amount) {
+    return "—";
+  }
+  return `${currency}${amount.toFixed(2)}`;
+}
