+import { formatMoney } from "@/Utils/money";
+
+interface PriceTagProps {
+  // amount comes straight from the pricing API; it is 0 for free / fully-discounted items
+  amount: number | null;
+  currency: string;
+}
+
+export function PriceTag({ amount, currency }: PriceTagProps) {
+  return <span className="price">{formatMoney(amount, currency)}</span>;
+}
